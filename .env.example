# Copy this file to .env and fill in real values. Never commit the real .env file.

# Long random string used to sign sessions / CSRF tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-value

# Set to "production" when deploying; keeps debug mode off and cookies strict.
FLASK_ENV=development

# SQLite database file path. A relative path (as below) is stored under
# the Flask instance folder (./instance/app.db); use "sqlite:////absolute/path.db"
# (four slashes) for an absolute path instead.
DATABASE_URL=sqlite:///app.db

# Initial admin account, created automatically on first run if it doesn't exist yet.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# Starting point balance given to every newly registered user.
STARTING_BALANCE=100000

# Number of reports before a product is auto-blocked / a user is auto-suspended.
REPORT_THRESHOLD=3
